# MongoDB — no password (local development, no auth enabled)
# Connection string used by the backend when running outside Docker
MONGODB_URI=mongodb://localhost:27017/ems_db

# OpenRouteService API key (optional — falls back to haversine if blank)
# Get a free key at https://openrouteservice.org/dev/#/signup
ORS_API_KEY=

# JWT Secret (minimum 32 characters)
JWT_SECRET=your-super-secret-key-at-least-32-characters-long

# Flutter App Configuration
API_BASE_URL=http://localhost:5000
SIGNALR_HUB_URL=http://localhost:5000/hubs/dispatch
