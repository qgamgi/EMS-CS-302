<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 9+ (API 28+) blocks cleartext (plain HTTP) traffic by default.
  This file explicitly allows cleartext traffic to private LAN IP ranges
  so the app can reach the local .NET backend over Wi-Fi.

  If you move to HTTPS (e.g. with a reverse proxy or ngrok), remove
  the <domain-config> block — the default system trust store handles HTTPS.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Allow plain HTTP to all private/LAN IPv4 ranges -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- 192.168.x.x -->
        <domain includeSubdomains="false">192.168.1.1</domain>
        <domain includeSubdomains="false">192.168.1.2</domain>
        <domain includeSubdomains="false">192.168.1.3</domain>
        <domain includeSubdomains="false">192.168.1.4</domain>
        <domain includeSubdomains="false">192.168.1.5</domain>
        <domain includeSubdomains="false">192.168.1.100</domain>
        <domain includeSubdomains="false">192.168.1.101</domain>
        <domain includeSubdomains="false">192.168.1.102</domain>
        <domain includeSubdomains="false">192.168.1.103</domain>
        <domain includeSubdomains="false">192.168.1.104</domain>
        <domain includeSubdomains="false">192.168.1.105</domain>
        <domain includeSubdomains="false">192.168.1.106</domain>
        <domain includeSubdomains="false">192.168.1.107</domain>
        <domain includeSubdomains="false">192.168.1.108</domain>
        <domain includeSubdomains="false">192.168.1.109</domain>
        <domain includeSubdomains="false">192.168.1.110</domain>
        <domain includeSubdomains="false">192.168.0.100</domain>
        <domain includeSubdomains="false">192.168.0.101</domain>
        <domain includeSubdomains="false">192.168.0.102</domain>
        <domain includeSubdomains="false">192.168.0.103</domain>
        <domain includeSubdomains="false">192.168.0.104</domain>
        <domain includeSubdomains="false">192.168.0.105</domain>
        <domain includeSubdomains="false">192.168.0.106</domain>
        <domain includeSubdomains="false">192.168.0.107</domain>
        <domain includeSubdomains="false">192.168.0.108</domain>
        <domain includeSubdomains="false">192.168.0.109</domain>
        <domain includeSubdomains="false">192.168.0.110</domain>
        <!-- 10.0.x.x range (some routers / hotspots use this) -->
        <domain includeSubdomains="false">10.0.0.1</domain>
        <domain includeSubdomains="false">10.0.0.2</domain>
        <domain includeSubdomains="false">10.0.1.1</domain>
        <!-- localhost / emulator (keep for dev builds) -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
</network-security-config>
