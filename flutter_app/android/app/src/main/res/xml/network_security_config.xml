<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 9+ (API 28+) blocks plain HTTP by default.
  This config allows cleartext HTTP to ALL hosts so the app can reach
  a local .NET backend on any LAN / hotspot IP without listing every IP.
  When you move to HTTPS in production, change cleartextTrafficPermitted
  to "false" on the base-config and remove the domain-config block.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
